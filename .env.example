MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nowaam
MONGODB_DB=nowaam

AUTH_SECRET=generate_with_openssl_rand_-base64_32

RAZORPAY_KEY_ID=rzp_test_yourkey
RAZORPAY_KEY_SECRET=your_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_yourkey

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# 1. Sign up at https://resend.com and create an API key
# 2. Add nowaam.com as a verified domain (Dashboard → Domains → Add Domain)
# 3. Add the SPF/DKIM/DMARC DNS records Resend shows for your domain
# 4. Once verified you can send from any address @nowaam.com
# Before domain verification, use onboarding@resend.dev as EMAIL_FROM for testing
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM=Nowaam <no-reply@nowaam.com>

NEXT_PUBLIC_APP_URL=http://localhost:3000

ADMIN_INVITE_CODE=your_secret_invite_code

# ─── Shipping / Delivery ────────────────────────────────────────────────────
# Set SHIPPING_PROVIDER=easypost for production, or leave as "mock" for dev/test
SHIPPING_PROVIDER=mock

# EasyPost (https://www.easypost.com) — use test key for dev, prod key for live
EASYPOST_API_KEY=EZTKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EASYPOST_WEBHOOK_SECRET=

# Shiprocket (https://shiprocket.in) — for shipments inside India
# 1. Create an API user at Settings → Additional Settings → API Users
# 2. Use that user's email + password here (NOT your main login)
# 3. Webhook token: set any random string here AND paste it into Shiprocket
#    Dashboard → Settings → Additional Settings → Webhooks → Token field
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_WEBHOOK_TOKEN=

# ─── Cron Jobs ──────────────────────────────────────────────────────────────
# Required for /api/cron/* endpoints (e.g. scheduled shipment tracking sync).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Vercel automatically sends `Authorization: Bearer ${CRON_SECRET}` to scheduled
# cron endpoints (configured in vercel.json).
CRON_SECRET=

# ─── SMS (Fast2SMS) ─────────────────────────────────────────────────────────
# https://fast2sms.com → API → Dev API
FAST2SMS_API_KEY=your_secret_invite_code
